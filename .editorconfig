root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 4

[*.{bat,cmd}]
end_of_line = crlf

[*.md]
trim_trailing_whitespace = false

# Фикстуры фильтра .fs-ignore намеренно пустые (демонстрируют сопоставление
# путей, а не содержимое) — не навязываем им финальный перевод строки, иначе
# редактор «дописывает» \n в 0-байтовые файлы и плодит фантомный diff.
[examples/10-ignore/**]
insert_final_newline = false
